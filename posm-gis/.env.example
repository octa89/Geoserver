# GeoServer proxy path (dev uses Vite proxy; prod uses Amplify rewrites or direct URL)
# VITE_GEOSERVER_BASE=/api/geoserver

# DynamoDB API Gateway URL (set after Amplify backend deploy)
# VITE_DYNAMO_API_URL=https://xxxxxxxxxx.execute-api.us-east-2.amazonaws.com

# GeoServer REST admin credentials (optional, for workspace discovery)
# VITE_GS_ADMIN_USER=admin
# VITE_GS_ADMIN_PASS=geoserver
